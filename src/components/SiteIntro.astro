<script>
const link = document.getElementById('software-link');
if (link) {
  link.addEventListener('mouseenter', () => {
    // Speculation Rules API (Chrome/Edge 109+)
    if (HTMLScriptElement.supports?.('speculationrules') && !document.querySelector('script[type="speculationrules"]')) {
      const spec = document.createElement('script');
      spec.type = 'speculationrules';
      spec.textContent = JSON.stringify({ prefetch: [{ urls: ['/software/'] }] });
      document.head.appendChild(spec);
    }
    // Fallback: <link rel="prefetch"> (all browsers)
    if (!document.querySelector('link[rel="prefetch"][href="/software/"]')) {
      const pf = document.createElement('link');
      pf.rel = 'prefetch';
      pf.href = '/software/';
      document.head.appendChild(pf);
    }
  }, { once: true });

}
</script>
